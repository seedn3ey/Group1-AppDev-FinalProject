<GridPane prefHeight="360.0" prefWidth="556.0" stylesheets="@css/main.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.CL">
