<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="620.0" styleClass="accounts-root" stylesheets="@css/show_accounts-view.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.ShowAccountsController">
    <children>
        <TableView fx:id="table" layoutX="55.0" layoutY="20.0" prefHeight="243.0" prefWidth="490.0" styleClass="accounts-table">
            <columns>
                <TableColumn fx:id="account" editable="false" prefWidth="200.0" text="Account Number" />
                <TableColumn fx:id="name" minWidth="100.0" prefWidth="75.0" text="Name" />
                <TableColumn fx:id="balance" minWidth="200.0" prefWidth="75.0" text="Account Balance" />
            </columns>
        </TableView>
        <Button fx:id="ModifyClick" layoutX="110.0" layoutY="302.0" mnemonicParsing="false" onAction="#OnModifyClick" styleClass="menu-button" text="Modify" />
        <Button fx:id="DeleteClick" layoutX="270.0" layoutY="302.0" mnemonicParsing="false" onAction="#OnDeleteClick" styleClass="menu-button" text="Delete" />
        <Button fx:id="backClick" layoutX="420.0" layoutY="302.0" mnemonicParsing="false" onAction="#OnBackClick" styleClass="menu-button" text="Back" />
    </children>
</AnchorPane>
