<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<GridPane prefHeight="650.0"
          prefWidth="1000.0"
          alignment="CENTER"
          hgap="20.0"
          vgap="25.0"
          stylesheets="@css/main.css"
          xmlns="http://javafx.com/javafx/26"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.gabriel.twoforms.CustomerLoginController">

    <!-- ================= Columns ================= -->

    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
    </columnConstraints>

    <!-- ================= Rows ================= -->

    <rowConstraints>
        <RowConstraints prefHeight="120"/>
        <RowConstraints prefHeight="90"/>
        <RowConstraints prefHeight="90"/>
        <RowConstraints prefHeight="90"/>
        <RowConstraints prefHeight="130"/>
    </rowConstraints>

    <children>

        <!-- ================= Watermark ================= -->

        <ImageView fitHeight="430"
                   fitWidth="430"
                   opacity="0.07"
                   preserveRatio="true"
                   pickOnBounds="true"
                   GridPane.columnSpan="4"
                   GridPane.rowSpan="5"
                   GridPane.halignment="CENTER"
                   GridPane.valignment="CENTER">

            <image>
                <Image url="@images/MapuaLogo.jpg"/>
            </image>

            <effect>
                <Blend mode="DARKEN"/>
            </effect>

            <cursor>
                <Cursor fx:constant="DEFAULT"/>
            </cursor>

        </ImageView>

        <!-- ================= Title ================= -->

        <Label text="Customer Login"
               GridPane.columnIndex="1"
               GridPane.columnSpan="2"
               GridPane.halignment="CENTER">

            <font>
                <Font size="40"/>
            </font>

        </Label>

        <!-- ================= Input ================= -->

        <Label text="Account Number"
               GridPane.columnIndex="1"
               GridPane.rowIndex="1"
               GridPane.columnSpan="2"
               GridPane.halignment="CENTER">

            <font>
                <Font size="20"/>
            </font>

        </Label>

        <TextField fx:id="tf_login_acc"
                   promptText="Enter Account Number"
                   prefWidth="350"
                   prefHeight="50"
                   GridPane.columnIndex="1"
                   GridPane.columnSpan="2"
                   GridPane.rowIndex="2"
                   GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </TextField>

        <!-- ================= Error Label ================= -->

        <Label fx:id="lbl_error"
               text="Please enter your account number."
               textFill="RED"
               wrapText="true"
               alignment="CENTER"
               GridPane.columnIndex="1"
               GridPane.columnSpan="2"
               GridPane.rowIndex="3"
               GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </Label>

        <!-- ================= Buttons ================= -->

        <HBox alignment="CENTER"
              spacing="30"
              GridPane.columnIndex="1"
              GridPane.columnSpan="2"
              GridPane.rowIndex="4">

            <children>

                <Button text="Back"
                        prefWidth="220"
                        prefHeight="60"
                        onAction="#OnBackClick">

                    <font>
                        <Font size="18"/>
                    </font>

                </Button>

                <Button text="Login"
                        prefWidth="220"
                        prefHeight="60"
                        onAction="#OnLoginSubmit">

                    <font>
                        <Font size="18"/>
                    </font>

                </Button>

            </children>

        </HBox>

    </children>

</GridPane>