<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<GridPane prefHeight="650.0"
          prefWidth="1000.0"
          alignment="CENTER"
          hgap="35.0"
          vgap="25.0"
          stylesheets="@css/main.css"
          xmlns="http://javafx.com/javafx/26"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.gabriel.twoforms.TransactionController">

    <!-- ================= Columns ================= -->

    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
    </columnConstraints>

    <!-- ================= Rows ================= -->

    <rowConstraints>
        <RowConstraints prefHeight="120"/>
        <RowConstraints prefHeight="90"/>
        <RowConstraints prefHeight="90"/>
        <RowConstraints prefHeight="90"/>
        <RowConstraints prefHeight="130"/>
    </rowConstraints>

    <children>

        <!-- ================= Watermark ================= -->

        <ImageView fitHeight="450"
                   fitWidth="450"
                   opacity="0.07"
                   preserveRatio="true"
                   pickOnBounds="true"
                   GridPane.columnSpan="4"
                   GridPane.rowSpan="5"
                   GridPane.halignment="CENTER"
                   GridPane.valignment="CENTER">

            <image>
                <Image url="@images/MapuaLogo.jpg"/>
            </image>

            <effect>
                <Blend mode="DARKEN"/>
            </effect>

            <cursor>
                <Cursor fx:constant="DEFAULT"/>
            </cursor>

        </ImageView>

        <!-- ================= Title ================= -->

        <Label text="Administrator Dashboard"
               alignment="CENTER"
               GridPane.columnIndex="1"
               GridPane.columnSpan="2"
               GridPane.halignment="CENTER">

            <font>
                <Font size="40"/>
            </font>

        </Label>

        <!-- ================= Create Account ================= -->

        <Button fx:id="btn_Create"
                text="Create Account"
                prefWidth="240"
                prefHeight="65"
                maxWidth="240"
                maxHeight="65"
                onAction="#createClick"
                GridPane.columnIndex="1"
                GridPane.rowIndex="1"
                GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </Button>

        <!-- ================= Deposit ================= -->

        <Button fx:id="btn_Deposit"
                text="Deposit"
                prefWidth="240"
                prefHeight="65"
                maxWidth="240"
                maxHeight="65"
                onAction="#depositClick"
                GridPane.columnIndex="2"
                GridPane.rowIndex="1"
                GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </Button>

        <!-- ================= Withdraw ================= -->

        <Button fx:id="btn_withdraw"
                text="Withdraw"
                prefWidth="240"
                prefHeight="65"
                maxWidth="240"
                maxHeight="65"
                onAction="#withdrawClick"
                GridPane.columnIndex="1"
                GridPane.rowIndex="2"
                GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </Button>

        <!-- ================= Balance ================= -->

        <Button fx:id="btn_Bal"
                text="View Balance"
                wrapText="true"
                prefWidth="240"
                prefHeight="65"
                maxWidth="240"
                maxHeight="65"
                onAction="#balanceClick"
                GridPane.columnIndex="2"
                GridPane.rowIndex="2"
                GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </Button>

        <!-- ================= View Accounts ================= -->

        <Button fx:id="view"
                text="Manage Accounts"
                prefWidth="240"
                prefHeight="65"
                maxWidth="240"
                maxHeight="65"
                onAction="#OnView"
                GridPane.columnIndex="1"
                GridPane.rowIndex="3"
                GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </Button>

        <!-- ================= Exit ================= -->

        <Button fx:id="btn_Exit"
                text="Exit"
                prefWidth="240"
                prefHeight="65"
                maxWidth="240"
                maxHeight="65"
                onAction="#exitClick"
                GridPane.columnIndex="2"
                GridPane.rowIndex="3"
                GridPane.halignment="CENTER">

            <font>
                <Font size="18"/>
            </font>

        </Button>

    </children>

</GridPane>